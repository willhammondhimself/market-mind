{
  "$schema": "http://json-schema.org/draft-07/schema#",
  "$id": "https://marketmind.local/schemas/session_config.schema.json",
  "title": "Session Configuration",
  "description": "Schema for session creation and configuration parameters",
  "type": "object",
  "properties": {
    "mode": {
      "enum": ["career", "practice", "challenge", "multiplayer"],
      "description": "Game mode: career (persistent), practice (no capital risk), challenge (timed with modifiers), or multiplayer (competitive)"
    },
    "assets": {
      "type": "array",
      "description": "List of ticker symbols to trade during this session",
      "items": {
        "type": "string",
        "minLength": 1,
        "maxLength": 10
      },
      "minItems": 1
    },
    "session_length": {
      "enum": ["2min", "5min", "15min", "endless"],
      "description": "Duration of the session (endless only valid for practice mode)"
    },
    "buy_in_amount": {
      "type": "number",
      "description": "Capital to risk in this session (required for career mode, ignored for practice)",
      "exclusiveMinimum": 0
    },
    "challenge_modes": {
      "type": "array",
      "description": "Array of challenge modifiers to apply (optional, only for challenge mode)",
      "items": {
        "enum": ["speed", "news_storm", "shark_tank", "thin_book", "volatility_regime", "nightmare"],
        "description": "Challenge modifier type"
      }
    },
    "preview_book": {
      "type": "boolean",
      "description": "Whether to show order book preview before session starts (costs capital if enabled)"
    }
  },
  "required": ["mode", "assets", "session_length"],
  "additionalProperties": false,
  "allOf": [
    {
      "if": {
        "properties": {
          "mode": {
            "const": "career"
          }
        }
      },
      "then": {
        "required": ["buy_in_amount"],
        "properties": {
          "buy_in_amount": {
            "exclusiveMinimum": 0
          }
        }
      }
    },
    {
      "if": {
        "properties": {
          "mode": {
            "const": "challenge"
          }
        }
      },
      "then": {
        "required": ["buy_in_amount"],
        "properties": {
          "buy_in_amount": {
            "exclusiveMinimum": 0
          }
        }
      }
    },
    {
      "if": {
        "properties": {
          "session_length": {
            "const": "endless"
          }
        }
      },
      "then": {
        "properties": {
          "mode": {
            "enum": ["practice"]
          }
        }
      }
    }
  ]
}
