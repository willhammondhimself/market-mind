{
  "$schema": "http://json-schema.org/draft-07/schema#",
  "$id": "https://marketmind.local/schemas/websocket_server.schema.json",
  "title": "WebSocket Server Messages",
  "description": "Schema for messages sent from server to client over WebSocket",
  "type": "object",
  "oneOf": [
    {
      "$ref": "#/definitions/BookMessage"
    },
    {
      "$ref": "#/definitions/TradeMessage"
    },
    {
      "$ref": "#/definitions/FillMessage"
    },
    {
      "$ref": "#/definitions/PnlMessage"
    },
    {
      "$ref": "#/definitions/NewsMessage"
    },
    {
      "$ref": "#/definitions/AlertMessage"
    },
    {
      "$ref": "#/definitions/SessionStateMessage"
    },
    {
      "$ref": "#/definitions/ScoreMessage"
    }
  ],
  "definitions": {
    "BookMessage": {
      "type": "object",
      "title": "Order Book Message",
      "description": "Current state of the order book for an asset",
      "properties": {
        "channel": {
          "const": "book",
          "description": "Channel identifier"
        },
        "asset": {
          "type": "string",
          "description": "Ticker symbol",
          "minLength": 1,
          "maxLength": 10
        },
        "bids": {
          "type": "array",
          "description": "Bid-side orders sorted by price (descending)",
          "items": {
            "type": "array",
            "minItems": 2,
            "maxItems": 2,
            "items": [
              {
                "type": "number",
                "description": "Bid price",
                "exclusiveMinimum": 0
              },
              {
                "type": "number",
                "description": "Accumulated size at this price level"
              }
            ]
          }
        },
        "asks": {
          "type": "array",
          "description": "Ask-side orders sorted by price (ascending)",
          "items": {
            "type": "array",
            "minItems": 2,
            "maxItems": 2,
            "items": [
              {
                "type": "number",
                "description": "Ask price",
                "exclusiveMinimum": 0
              },
              {
                "type": "number",
                "description": "Accumulated size at this price level"
              }
            ]
          }
        },
        "timestamp": {
          "type": "integer",
          "description": "Unix timestamp in milliseconds when book was generated",
          "minimum": 0
        }
      },
      "required": ["channel", "asset", "bids", "asks", "timestamp"],
      "additionalProperties": false
    },
    "TradeMessage": {
      "type": "object",
      "title": "Trade Message",
      "description": "Notification of a market trade execution",
      "properties": {
        "channel": {
          "const": "trade",
          "description": "Channel identifier"
        },
        "asset": {
          "type": "string",
          "description": "Ticker symbol",
          "minLength": 1,
          "maxLength": 10
        },
        "price": {
          "type": "number",
          "description": "Execution price",
          "exclusiveMinimum": 0
        },
        "size": {
          "type": "integer",
          "description": "Execution quantity",
          "minimum": 1
        },
        "aggressor_side": {
          "enum": ["buy", "sell"],
          "description": "Side initiating the trade"
        },
        "is_yours": {
          "type": "boolean",
          "description": "Whether the client's order was involved in this trade"
        },
        "counterparty": {
          "type": ["string", "null"],
          "description": "Counterparty identifier (null if not applicable or anonymous)"
        },
        "timestamp": {
          "type": "integer",
          "description": "Unix timestamp in milliseconds when trade occurred",
          "minimum": 0
        }
      },
      "required": ["channel", "asset", "price", "size", "aggressor_side", "is_yours", "counterparty", "timestamp"],
      "additionalProperties": false
    },
    "FillMessage": {
      "type": "object",
      "title": "Order Fill Message",
      "description": "Notification that client's order has been partially or fully filled",
      "properties": {
        "channel": {
          "const": "fill",
          "description": "Channel identifier"
        },
        "asset": {
          "type": "string",
          "description": "Ticker symbol",
          "minLength": 1,
          "maxLength": 10
        },
        "order_id": {
          "type": "string",
          "description": "Unique identifier of the filled order",
          "minLength": 1
        },
        "side": {
          "enum": ["bid", "ask"],
          "description": "Order side: 'bid' for buy, 'ask' for sell"
        },
        "price": {
          "type": "number",
          "description": "Execution price of this fill",
          "exclusiveMinimum": 0
        },
        "size": {
          "type": "integer",
          "description": "Quantity filled in this execution",
          "minimum": 1
        },
        "remaining_size": {
          "type": "integer",
          "description": "Quantity still outstanding after this fill",
          "minimum": 0
        },
        "timestamp": {
          "type": "integer",
          "description": "Unix timestamp in milliseconds when fill occurred",
          "minimum": 0
        }
      },
      "required": ["channel", "asset", "order_id", "side", "price", "size", "remaining_size", "timestamp"],
      "additionalProperties": false
    },
    "PnlMessage": {
      "type": "object",
      "title": "PnL Message",
      "description": "Updated profit/loss information and inventory position",
      "properties": {
        "channel": {
          "const": "pnl",
          "description": "Channel identifier"
        },
        "realized": {
          "type": "number",
          "description": "Realized profit/loss from closed positions"
        },
        "unrealized": {
          "type": "number",
          "description": "Unrealized profit/loss from open positions"
        },
        "inventory": {
          "type": "object",
          "description": "Current inventory position by asset",
          "additionalProperties": {
            "type": "integer",
            "description": "Quantity held (positive=long, negative=short)"
          }
        },
        "total_pnl": {
          "type": "number",
          "description": "Total P&L (realized + unrealized)"
        },
        "timestamp": {
          "type": "integer",
          "description": "Unix timestamp in milliseconds when this update was generated",
          "minimum": 0
        }
      },
      "required": ["channel", "realized", "unrealized", "inventory", "total_pnl", "timestamp"],
      "additionalProperties": false
    },
    "NewsMessage": {
      "type": "object",
      "title": "News Message",
      "description": "Market news update that may affect trading decisions",
      "properties": {
        "channel": {
          "const": "news",
          "description": "Channel identifier"
        },
        "headline": {
          "type": "string",
          "description": "News headline text",
          "minLength": 1
        },
        "news_type": {
          "enum": ["earnings", "macro", "sector", "geopolitical", "company"],
          "description": "Category of news event"
        },
        "affected_assets": {
          "type": "array",
          "description": "List of ticker symbols affected by this news",
          "items": {
            "type": "string",
            "minLength": 1,
            "maxLength": 10
          }
        },
        "timestamp": {
          "type": "integer",
          "description": "Unix timestamp in milliseconds when news occurred or was published",
          "minimum": 0
        }
      },
      "required": ["channel", "headline", "news_type", "affected_assets", "timestamp"],
      "additionalProperties": false
    },
    "AlertMessage": {
      "type": "object",
      "title": "Alert Message",
      "description": "System alert to notify client of important events or warnings",
      "properties": {
        "channel": {
          "const": "alert",
          "description": "Channel identifier"
        },
        "alert_type": {
          "enum": ["inventory_warning", "time_warning", "session_end", "countdown"],
          "description": "Type of alert being raised"
        },
        "message": {
          "type": "string",
          "description": "Human-readable alert message",
          "minLength": 1
        },
        "severity": {
          "enum": ["info", "warning", "critical"],
          "description": "Severity level of the alert"
        },
        "timestamp": {
          "type": "integer",
          "description": "Unix timestamp in milliseconds when alert was generated",
          "minimum": 0
        }
      },
      "required": ["channel", "alert_type", "message", "severity", "timestamp"],
      "additionalProperties": false
    },
    "SessionStateMessage": {
      "type": "object",
      "title": "Session State Message",
      "description": "Updates to the overall session state and timing information",
      "properties": {
        "channel": {
          "const": "session_state",
          "description": "Channel identifier"
        },
        "state": {
          "enum": ["countdown", "active", "ending", "ended"],
          "description": "Current session state"
        },
        "countdown_value": {
          "type": ["integer", "null"],
          "description": "Countdown time value (relevant for 'countdown' state)",
          "minimum": 0
        },
        "time_remaining_ms": {
          "type": ["integer", "null"],
          "description": "Milliseconds remaining in active session (null if not applicable)",
          "minimum": 0
        },
        "timestamp": {
          "type": "integer",
          "description": "Unix timestamp in milliseconds when this state change occurred",
          "minimum": 0
        }
      },
      "required": ["channel", "state", "countdown_value", "time_remaining_ms", "timestamp"],
      "additionalProperties": false
    },
    "ScoreMessage": {
      "type": "object",
      "title": "Score Message",
      "description": "Performance score and metrics (typically sent at session end)",
      "properties": {
        "channel": {
          "const": "score",
          "description": "Channel identifier"
        },
        "letter_grade": {
          "enum": ["S", "A", "B", "C", "D", "F"],
          "description": "Overall letter grade"
        },
        "composite_score": {
          "type": "number",
          "description": "Weighted composite score (0-100)"
        },
        "pnl": {
          "type": "number",
          "description": "Profit/loss component score"
        },
        "sharpe": {
          "type": "number",
          "description": "Sharpe ratio component score"
        },
        "max_drawdown": {
          "type": "number",
          "description": "Maximum drawdown component score"
        },
        "avg_spread": {
          "type": "number",
          "description": "Average spread efficiency score"
        },
        "capital_change": {
          "type": "number",
          "description": "Change in capital amount"
        },
        "new_capital": {
          "type": "number",
          "description": "Total capital after session"
        },
        "streak_count": {
          "type": "integer",
          "description": "Current winning/performance streak count",
          "minimum": 0
        },
        "multiplier": {
          "type": "number",
          "description": "Score multiplier based on challenge modes or difficulty",
          "minimum": 1
        }
      },
      "required": ["channel", "letter_grade", "composite_score", "pnl", "sharpe", "max_drawdown", "avg_spread", "capital_change", "new_capital", "streak_count", "multiplier"],
      "additionalProperties": false
    }
  }
}
